-- Slider logic
local MIN_SIZE, MAX_SIZE = 2, 60
local dragging = false

local function updateSlider(pct)
    pct = math.clamp(pct, 0, 1)
    local newSize = math.floor(MIN_SIZE + pct * (MAX_SIZE - MIN_SIZE))
    getgenv().HBE_SIZE = newSize
    sizeLabel.Text = "Size: " .. newSize
    fill.Size = UDim2.new(pct, 0, 1, 0)
    knob.Position = UDim2.new(pct, 0, 0.5, 0)
end

local function getPct(inputX)
    local trackPos = track.AbsolutePosition.X
    local trackWidth = track.AbsoluteSize.X
    return (inputX - trackPos) / trackWidth
end

knob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
    end
end)

track.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        updateSlider(getPct(input.Position.X))
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        updateSlider(getPct(input.Position.X))
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Hotkey K
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.K then
        setState(not getgenv().HBE)
    end
end)

-- === HITBOX LOGIC ===
local function AssignHitboxes(player)
    if player == LocalPlayer then return end
    RunService.RenderStepped:Connect(function()
        local char = CHAR_PARENT and CHAR_PARENT:FindFirstChild(player.Name)
        if getgenv().HBE then
            if char and char:FindFirstChild("HumanoidRootPart") then
                local s = getgenv().HBE_SIZE
                local hrp = char.HumanoidRootPart
                hrp.Size = Vector3.new(s, s, s)
                hrp.Color = HITBOX_COLOUR
                hrp.CanCollide = false
                hrp.Transparency = 0.5
            end
        else
            if char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
                char.HumanoidRootPart.Transparency = 1
            end
        end
    end)
end

for _, player in ipairs(Players:GetPlayers()) do
    AssignHitboxes(player)
end

Players.PlayerAdded:Connect(function(player)
    AssignHitboxes(player)
end)

